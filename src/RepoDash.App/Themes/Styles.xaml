<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style TargetType="Window">
    <Setter Property="Background" Value="{StaticResource BrushBaseBg}"/>
    <Setter Property="Foreground" Value="{StaticResource BrushTextMain}"/>
  </Style>

  <!-- TextBox -->
  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource BrushTextMain}"/>
    <Setter Property="Background" Value="{StaticResource BrushCardBg}"/>
    <Setter Property="BorderBrush" Value="#2B323B"/>
  </Style>

  <!-- ListBox + item -->
  <Style TargetType="ListBox">
    <Setter Property="Foreground" Value="{StaticResource BrushTextMain}"/>
    <Setter Property="Background" Value="{StaticResource BrushBaseBg}"/>
    <Setter Property="BorderBrush" Value="#2B323B"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>
  <Style TargetType="ListBoxItem">
    <Setter Property="Padding" Value="6"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource BrushTextMain}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListBoxItem">
          <Border Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0" CornerRadius="4">
            <ContentPresenter />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#1F2A33"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="#26323D"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Cards and icon-only button -->
  <Style x:Key="Card" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource BrushCardBg}"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="8"/>
  </Style>

  <Style x:Key="IconFlatButton" TargetType="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="Padding" Value="6"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}" CornerRadius="6">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#242A31"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
